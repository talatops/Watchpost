# =============================================================================
# Watchpost — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all required values before running.
# NEVER commit a filled-in .env to source control.
# =============================================================================

# --- DATABASE — PostgreSQL ----------------------------------------------------
# Local/Docker: use postgres/postgres defaults below.
# Production: CREATE USER mdm WITH PASSWORD '...'; GRANT ALL ON DATABASE mdm_db TO mdm;
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mdm_db
DB_SSLMODE=disable
DATABASE_URL=host=postgres port=5432 user=postgres password=postgres dbname=mdm_db sslmode=disable

# --- SECURITY — JWT Secrets ---------------------------------------------------
# Generate with: openssl rand -base64 48
# Use DIFFERENT values for admin and device secrets. Min 32 chars.
JWT_SECRET=REPLACE_ME_openssl_rand_base64_48
DEVICE_JWT_SECRET=REPLACE_ME_different_openssl_rand_base64_48

# --- SERVER -------------------------------------------------------------------
PORT=8080
# Externally reachable URL (used in QR codes and email links)
SERVER_URL=http://localhost:8080
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- FIREBASE CLOUD MESSAGING (FCM) ------------------------------------------
# Get from: Firebase Console → Project Settings → Cloud Messaging → Server key
# Legacy server key starts with "AAAA..."
FCM_SERVER_KEY=REPLACE_ME_FIREBASE_SERVER_KEY
# Firebase Project ID: Firebase Console → Project Settings → General → Project ID
FIREBASE_PROJECT_ID=REPLACE_ME_FIREBASE_PROJECT_ID

# --- SMTP — Email delivery (invitations, alerts, password resets) -------------
# Option A — Gmail: host=smtp.gmail.com port=587
#   Password = App Password from myaccount.google.com/apppasswords
# Option B — AWS SES: host=email-smtp.us-east-1.amazonaws.com port=587
#   Credentials from: AWS Console → SES → SMTP Settings → Create credentials
# Option C — Resend (resend.com): host=smtp.resend.com user=resend password=re_xxx
# Option D — Mailgun: host=smtp.mailgun.org user=postmaster@mg.yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME_YOUR_EMAIL_ADDRESS
SMTP_PASSWORD=REPLACE_ME_APP_PASSWORD_OR_SMTP_KEY
SMTP_TLS=true
SMTP_FROM=Watchpost <noreply@yourdomain.com>

# --- MINIO — Object storage (APKs, OTA packages, exports) --------------------
# Local/Docker: MinIO runs via docker-compose on port 9000.
# Production: deploy MinIO or use AWS S3 (set endpoint + credentials accordingly).
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_ME_STRONG_MINIO_PASSWORD
MINIO_USE_SSL=false
MINIO_BUCKET_APPS=mdm-apps
MINIO_BUCKET_OTA=mdm-ota
MINIO_BUCKET_EXPORTS=mdm-exports

# AWS S3 alternative (leave blank to use MinIO above)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# --- REDIS — Cache and job queue ----------------------------------------------
# Local/Docker: redis://redis:6379 (no password)
# Cloud options: Upstash (free tier at upstash.com), Redis Cloud, AWS ElastiCache
REDIS_URL=redis://redis:6379

# --- BOOTSTRAP — First admin account (seeded on first start) ------------------
# Change SEED_ADMIN_PASSWORD immediately after first login.
SEED_ORG_NAME=My Organization
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# --- ANDROID AGENT ------------------------------------------------------------
# This token is embedded in QR enrollment codes. Use a cryptographically random value.
# Generate with: openssl rand -hex 32
DEFAULT_ENROLLMENT_TOKEN=REPLACE_ME_openssl_rand_hex_32

# --- OPTIONAL — Observability -------------------------------------------------
# SENTRY_DSN=https://....ingest.sentry.io/...
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# LOG_LEVEL=info
